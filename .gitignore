.idea/misc.xml
.idea/modules.xml
.idea/encodings.xml
.idea/runConfigurations/
.idea/libraries/
.idea/artifacts/
.idea/jarRepositories.xml
.idea/shelf/

### Allow these IntelliJ files (project-specific but not user-specific) ###
!.idea/description.html
!.idea/icon.png
!.idea/runConfigurations/README.txt